### Admin vouchers - List
GET {{baseUrl}}/api/admin/vouchers
Authorization: Bearer {{adminToken}}
Accept: application/json

### Admin vouchers - Get by id
GET {{baseUrl}}/api/admin/vouchers/{{voucherId}}
Authorization: Bearer {{adminToken}}
Accept: application/json

### Admin vouchers - Create
POST {{baseUrl}}/api/admin/vouchers
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "code": "REST{{$randomInt 1000 9999}}",
  "discountType": "PERCENTAGE",
  "discountValue": 10,
  "minOrderValue": 50000,
  "maxDiscountAmount": 25000,
  "validFrom": "2026-06-29T00:00:00.000Z",
  "validUntil": "2026-12-31T23:59:59.000Z",
  "usageLimit": 100,
  "isActive": true
}

### Admin vouchers - Update
PUT {{baseUrl}}/api/admin/vouchers/{{voucherId}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "code": "RESTUPDATED",
  "discountType": "FIXED",
  "discountValue": 15000,
  "minOrderValue": 50000,
  "maxDiscountAmount": null,
  "validFrom": "2026-06-29T00:00:00.000Z",
  "validUntil": "2026-12-31T23:59:59.000Z",
  "usageLimit": 50,
  "isActive": true
}

### Admin vouchers - Delete
DELETE {{baseUrl}}/api/admin/vouchers/{{voucherId}}
Authorization: Bearer {{adminToken}}
Accept: application/json

### Admin settings - List
GET {{baseUrl}}/api/admin/settings
Authorization: Bearer {{adminToken}}
Accept: application/json

### Admin settings - Create
POST {{baseUrl}}/api/admin/settings
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "key": "rest_client_setting_{{$timestamp}}",
  "value": "enabled",
  "description": "Created from REST Client"
}

### Admin settings - Update
PUT {{baseUrl}}/api/admin/settings/{{settingId}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "key": "rest_client_setting_updated",
  "value": "disabled",
  "description": "Updated from REST Client"
}

### Admin settings - Delete
DELETE {{baseUrl}}/api/admin/settings/{{settingId}}
Authorization: Bearer {{adminToken}}
Accept: application/json

### Vouchers - Validate
POST {{baseUrl}}/api/vouchers/validate
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "code": "RESTUPDATED",
  "subtotal": 120000
}

