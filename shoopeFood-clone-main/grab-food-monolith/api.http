# GrabFood Monolith API collection for VS Code REST Client
# Run the login requests first. Token variables below are taken from their responses.

@baseUrl = http://localhost:3000

# Current auto seed accounts when DB is empty. Password is "123".
@customerPhone = 0901234567
@customerPassword = 123
@merchantPhone = 0911111111
@merchantPassword = 123
@driverPhone = 0981111111
@driverPassword = 123
# Current seedService assigns ADMIN to the user with phone 0905678901.
@adminPhone = 0905678901
@adminPassword = 123

# Legacy seed_all.sql / old audit script accounts use password "123456":
# CUSTOMER 0900000001, DRIVER 0900000002, MERCHANT 0900000003, ADMIN 0900000005.

@adminToken = {{loginAdmin.response.body.$.data.token}}
@merchantToken = {{loginMerchant.response.body.$.data.token}}
@customerToken = {{loginCustomer.response.body.$.data.token}}
@driverToken = {{loginDriver.response.body.$.data.token}}

@userId = 1
@customerId = 1
@merchantOwnerId = 6
@driverId = 9
@restaurantId = 1
@categoryId = 1
@foodId = 1
@toppingId = 1
@orderId = 1
@paymentId = 1
@voucherId = 1
@settingId = 1
@addressId = 1
@driverPenaltyId = 1
@restaurantChangeRequestId = 1
@placeId = manual-demo-place

# Order status codes:
# PENDING, CONFIRMED, DRIVER_ACCEPTED, DRIVER_REJECTED, PICKING_UP, DELIVERING, COMPLETED, CANCELLED, TIMEOUT

### Health - Categories public
GET {{baseUrl}}/api/categories
Accept: application/json

### Auth - Login admin
# @name loginAdmin
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "phone": "{{adminPhone}}",
  "password": "{{adminPassword}}",
  "role": "ADMIN"
}

### Auth - Login merchant
# @name loginMerchant
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "phone": "{{merchantPhone}}",
  "password": "{{merchantPassword}}",
  "role": "MERCHANT"
}

### Auth - Login customer
# @name loginCustomer
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "phone": "{{customerPhone}}",
  "password": "{{customerPassword}}",
  "role": "CUSTOMER"
}

### Auth - Login driver
# @name loginDriver
POST {{baseUrl}}/api/auth/login
Content-Type: application/json

{
  "phone": "{{driverPhone}}",
  "password": "{{driverPassword}}",
  "role": "DRIVER"
}

### Auth - Register customer
POST {{baseUrl}}/api/auth/register
Content-Type: application/json

{
  "fullName": "REST Client Customer",
  "phone": "03{{$randomInt 10000000 99999999}}",
  "password": "Demo123"
}

### Auth - Me
GET {{baseUrl}}/api/auth/me
Authorization: Bearer {{customerToken}}
Accept: application/json

### Auth - Update profile
PUT {{baseUrl}}/api/auth/profile
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "fullName": "REST Client Customer",
  "phone": "{{customerPhone}}"
}

### Auth - Change password
# This changes the password for the logged-in account.
PUT {{baseUrl}}/api/auth/password
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "currentPassword": "{{customerPassword}}",
  "newPassword": "Customer123"
}

### Auth - Activate role
POST {{baseUrl}}/api/auth/activate-role
Authorization: Bearer {{customerToken}}
Content-Type: application/json

{
  "role": "CUSTOMER"
}

### Auth - Forgot password
POST {{baseUrl}}/api/auth/forgot-password
Content-Type: application/json

{
  "phone": "{{customerPhone}}"
}

### Auth - Reset password
POST {{baseUrl}}/api/auth/reset-password
Content-Type: application/json

{
  "phone": "{{customerPhone}}",
  "otp": "123456",
  "newPassword": "Customer123"
}

### Users - Current profile
GET {{baseUrl}}/api/users/me
Authorization: Bearer {{customerToken}}
Accept: application/json

### Users - List merchants
GET {{baseUrl}}/api/users/merchants
Authorization: Bearer {{adminToken}}
Accept: application/json

### Users - Create merchant
POST {{baseUrl}}/api/users/merchants
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "fullName": "REST Merchant",
  "phone": "07{{$randomInt 10000000 99999999}}",
  "password": "Merchant123",
  "ratingAvg": 5
}

### Users - List users
GET {{baseUrl}}/api/users
Authorization: Bearer {{adminToken}}
Accept: application/json

### Users - Get user by id
GET {{baseUrl}}/api/users/{{userId}}
Authorization: Bearer {{adminToken}}
Accept: application/json

### Users - Create user
POST {{baseUrl}}/api/users
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "fullName": "REST Created User",
  "phone": "08{{$randomInt 10000000 99999999}}",
  "password": "User123",
  "ratingAvg": 5,
  "role": "CUSTOMER"
}

### Users - Update user
PUT {{baseUrl}}/api/users/{{userId}}
Authorization: Bearer {{adminToken}}
Content-Type: application/json

{
  "fullName": "REST Updated User",
  "phone": "{{customerPhone}}",
  "ratingAvg": 4.9,
  "role": "CUSTOMER"
}

### Users - Delete user
DELETE {{baseUrl}}/api/users/{{userId}}
Authorization: Bearer {{adminToken}}
Accept: application/json

