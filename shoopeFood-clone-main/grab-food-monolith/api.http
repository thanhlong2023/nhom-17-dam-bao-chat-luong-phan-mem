  "ownerId": {{merchantOwnerId}},
  "name": "REST Pho House",
  "address": "413 Nguyen Trai, District 5, Ho Chi Minh City",
  "latitude": 10.7554,
  "longitude": 106.6669,
  "openingTime": "07:00:00",
  "closingTime": "22:00:00",
  "isOpen": true,
  "imageUrl": "https://example.com/pho.jpg",
  "ratingAvg": 5
}

### Restaurants - Update open status
PATCH {{baseUrl}}/api/restaurants/{{restaurantId}}/status
Authorization: Bearer {{merchantToken}}
Content-Type: application/json

{
  "isOpen": true
}

### Restaurants - Update today status
PATCH {{baseUrl}}/api/restaurants/{{restaurantId}}/today-status
Authorization: Bearer {{merchantToken}}
Content-Type: application/json

{
  "isOpenToday": true,
  "reason": null,
  "temporaryClosedUntil": null
}

